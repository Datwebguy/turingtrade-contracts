# ── Required keys ─────────────────────────────────────────────────────────────
# Private key of the deployer / owner wallet (creates rounds, withdraws fees)
DEPLOYER_PRIVATE_KEY=0x_your_deployer_private_key

# Separate private key used by the AI agent bot (never reuse the deployer key)
AGENT_PRIVATE_KEY=0x_your_agent_private_key

# OpenRouter key (https://openrouter.ai) or Anthropic key (https://console.anthropic.com)
AI_API_KEY=sk-or-v1-...

# ── Optional — keeper bot ──────────────────────────────────────────────────────
# Defaults to DEPLOYER_PRIVATE_KEY if not set
KEEPER_PRIVATE_KEY=0x_your_keeper_private_key

# ── Optional — RPC / network ───────────────────────────────────────────────────
RPC_URL=https://rpc.sepolia.mantle.xyz

# ── Optional — AI model ────────────────────────────────────────────────────────
AI_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=openai/gpt-oss-20b:free

# ── Optional — round parameters ────────────────────────────────────────────────
ENTRY_FEE_MNT=0.1
ROUND_DURATION_HOURS=1

# ── Contract addresses ─────────────────────────────────────────────────────────
# Auto-populated by deploy.js — override here if you're pointing at an existing deployment
TURING_ROUND_ADDRESS=
AGENT_REGISTRY_ADDRESS=
REASONING_LOG_ADDRESS=
TRADE_EXECUTOR_ADDRESS=
